# ============================================================
# .env.example — environment template for the evaluation pipeline
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored; never commit real secrets.
# Docker Compose reads this file automatically from the project root.
# ============================================================

# --- Inference credentials ---------------------------------

# Nebius Token Factory API key, used by mini-swe-agent for LLM calls.
# Obtain from your Nebius console. Format: NO spaces around '='.
NEBIUS_API_KEY=

# Optional: HuggingFace token. Avoids dataset-download rate limits
# for SWE-bench datasets. Leave empty if not needed.
HF_TOKEN=

# --- Airflow (docker-compose) ------------------------------

# Host user ID that Airflow containers run as, so files written to
# mounted volumes (dags/, logs/, runs/) belong to you, not root.
# Set with:  echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=1000

# Key for encrypting secrets (connections/variables) in Airflow's
# metadata DB. Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- Docker socket access ----------------------------------

# GID of the host's 'docker' group. Added to the Airflow containers
# (group_add) so DockerOperator can use the mounted /var/run/docker.sock.
# Set with:  echo "DOCKER_GID=$(getent group docker | cut -d: -f3)" >> .env
DOCKER_GID=999

# --- Path translation (three-worlds problem) ---------------

# Absolute HOST path of this project. Needed because the DAG runs inside
# a container but launches sibling containers via the host Docker daemon:
# bind-mount sources must be HOST paths, which the container cannot infer.
# Example: /home/bonse/mlops-e2e-ml-pipeline
HOST_PROJECT_DIR=

# --- MLflow ------------------------------------------------

# Where the MLflow client logs to. Inside docker-compose this is the
# service DNS name; for standalone/local use http://localhost:5000.
# (Set in docker-compose.yaml for containers; here for host-side runs.)
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Object Storage (Nebius, S3-compatible) ----------------
# Long-term storage for run artifacts: upload_to_s3 copies each
# runs/<run-id>/ folder here and records the URI in manifest.json + MLflow.

# Service-account credentials for Object Storage, created via the Nebius
# CLI/console. boto3 reads these two automatically — the names must stay
# exactly AWS_* even though the provider is Nebius (S3 API convention).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 endpoint URL for your Nebius region, as shown in the Nebius console.
# Required because boto3 defaults to Amazon's endpoints.
# Example: https://storage.eu-north1.nebius.cloud
S3_ENDPOINT_URL=

# Bucket that receives run artifacts (must already exist).
# Objects are written under runs/<run-id>/.
S3_BUCKET=mlops-agent-evals

# Required well-formed by botocore; content ignored by MinIO, must match region for real Nebius"
AWS_DEFAULT_REGION=eu-north-1